APP_NAME="PoliçeAsist"
# Canlı sunucuda production yapın; kurulum sihirbazı (/install) bu ortamda zorunludur (install.lock oluşana kadar).
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: APP_DEBUG=false, APP_ENV=production
# Canlı örnek: APP_URL=https://policeasist.com.tr
APP_URL=http://localhost
# Production (TLS): set true so URL::forceScheme('https') runs
FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Yerel ve canlı: MySQL 8.x (utf8mb4). Önce veritabanını oluşturun: CREATE DATABASE policeasist CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=policeasist
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Production: consider SESSION_ENCRYPT=true
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production behind HTTPS: SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
